---
---

<div class="koledar">
  <div class="koledar__header">
    <h1 class="koledar__title">Ekonomski koledar</h1>
    <p class="koledar__subtitle">
      Ključni makroekonomski dogodki in zaslužki največjih podjetij - naslednjih 90 dni.
      Časi so v CET/CEST. Datumi zaslužkov so okvirni.
    </p>
  </div>

  <div class="koledar__toolbar">
    <div class="koledar__filters" id="koledar-filters" role="group" aria-label="Filtriraj dogodke">
      <button class="filter-btn filter-btn--active" data-filter="vsi">Vsi dogodki</button>
      <button class="filter-btn" data-filter="makro">Makro</button>
      <button class="filter-btn" data-filter="zasluzki">Zaslužki</button>
    </div>

    <div class="koledar__views" id="koledar-views" role="group" aria-label="Način prikaza">
      <button class="filter-btn filter-btn--active" data-view="list">Seznam</button>
      <button class="filter-btn" data-view="month">Koledar</button>
    </div>
  </div>

  <div id="koledar-events"></div>

  <div id="koledar-month" hidden>
    <div class="cal-month-nav">
      <button type="button" class="cal-month-nav__btn" id="cal-prev" aria-label="Prejšnji mesec">‹</button>
      <span class="cal-month-nav__label" id="cal-month-label"></span>
      <button type="button" class="cal-month-nav__btn" id="cal-next" aria-label="Naslednji mesec">›</button>
    </div>
    <div class="cal-grid" id="cal-grid"></div>
    <div id="cal-day-detail"></div>
  </div>
</div>

<style is:global>
  .koledar {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md) var(--space-3xl);
  }

  .koledar__header {
    margin-bottom: var(--space-xl);
  }

  .koledar__title {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }

  .koledar__subtitle {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .koledar__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .koledar__filters,
  .koledar__views {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.375rem 1rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
    background: var(--color-surface-hover);
  }

  .filter-btn--active {
    color: var(--color-accent);
    background: var(--color-accent-bg);
    border-color: var(--color-accent-border);
    font-weight: 600;
  }

  .cal-week {
    margin-bottom: var(--space-xl);
  }

  .cal-week__header {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.75rem;
  }

  .cal-item {
    margin-bottom: 0.4rem;
  }

  .cal-row {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: border-color 150ms ease;
    cursor: pointer;
    width: 100%;
    text-align: left;
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    -webkit-appearance: none;
    appearance: none;
  }

  .cal-item .cal-row {
    border-bottom-left-radius: var(--radius-md);
    border-bottom-right-radius: var(--radius-md);
  }

  .cal-item--open .cal-row {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    border-bottom-color: transparent;
  }

  .cal-row:hover {
    border-color: var(--color-border-strong);
  }

  .cal-row--today {
    border-color: var(--color-accent-border);
    background: var(--color-accent-bg);
  }

  .cal-row--past {
    opacity: 0.5;
  }

  .cal-date {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cal-day {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .cal-row--today .cal-day {
    color: var(--color-accent);
  }

  .cal-time {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .cal-main {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .cal-event-title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
  }

  .cal-ticker {
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .cal-expand-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-subtle);
    transition: transform 150ms ease;
    flex-shrink: 0;
  }

  .cal-item--open .cal-expand-icon {
    transform: rotate(180deg);
  }

  .cal-meta {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .cal-hint {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .cal-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 1px 7px;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .cal-badge--high {
    background: rgba(220, 38, 38, 0.1);
    color: #dc2626;
    border: 1px solid rgba(220, 38, 38, 0.25);
  }

  .cal-badge--medium {
    background: rgba(217, 119, 6, 0.1);
    color: #b45309;
    border: 1px solid rgba(217, 119, 6, 0.25);
  }

  .cal-badge--earnings {
    background: rgba(37, 99, 235, 0.1);
    color: var(--color-accent);
    border: 1px solid var(--color-accent-border);
  }

  .cal-badge--region {
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    font-weight: 500;
  }

  .cal-badge--cat {
    background: var(--color-surface-hover);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .cal-badge--actual {
    background: rgba(5, 150, 105, 0.1);
    color: #059669;
    border: 1px solid rgba(5, 150, 105, 0.3);
    font-weight: 600;
  }

  .cal-empty {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .cal-row__end {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cal-detail {
    display: none;
    padding: 0.75rem 0.9rem 0.9rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: none;
    border-bottom-left-radius: var(--radius-md);
    border-bottom-right-radius: var(--radius-md);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .cal-item--open .cal-detail {
    display: block;
  }

  .cal-detail p {
    margin: 0 0 0.5rem;
  }

  .cal-detail__stats {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cal-detail__stats strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .cal-month-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-lg);
  }

  .cal-month-nav__label {
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.01em;
    text-transform: capitalize;
  }

  .cal-month-nav__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-size: var(--text-lg);
    line-height: 1;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .cal-month-nav__btn:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
    background: var(--color-surface-hover);
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    margin-bottom: var(--space-lg);
  }

  .cal-grid__weekday {
    text-align: center;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
    padding-bottom: var(--space-sm);
  }

  .cal-day-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    min-height: 3.25rem;
    padding: 0.4rem 0.2rem;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    background: var(--color-surface);
    cursor: default;
    font-family: inherit;
    color: inherit;
    -webkit-appearance: none;
    appearance: none;
  }

  .cal-day-cell--muted {
    background: transparent;
    color: var(--color-text-subtle);
  }

  .cal-day-cell--has-events {
    cursor: pointer;
    border-color: var(--color-border);
  }

  .cal-day-cell--has-events:hover {
    border-color: var(--color-border-strong);
    background: var(--color-surface-hover);
  }

  .cal-day-cell--today .cal-day-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
  }

  .cal-day-cell--selected {
    border-color: var(--color-accent-border);
    background: var(--color-accent-bg);
  }

  .cal-day-num {
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .cal-day-dots {
    display: flex;
    gap: 3px;
  }

  .cal-day-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .cal-day-dot--high { background: #dc2626; }
  .cal-day-dot--medium { background: #b45309; }
  .cal-day-dot--earnings { background: var(--color-accent); }

  .cal-day-detail__hint {
    text-align: center;
    padding: var(--space-xl) 0;
    color: var(--color-text-subtle);
    font-size: var(--text-sm);
  }
</style>

<script>
  import koledarData from '../../data/koledar-events.json';

  type MacroEvent = {
    id: string; date: string; time?: string; title: string;
    category: string; region: 'US' | 'EU'; importance: 'HIGH' | 'MEDIUM';
    previous?: string; forecast?: string; actual?: string;
  };
  type EarningsEvent = {
    id: string; date: string; ticker: string; name: string; when: string;
    prevEps?: string; estEps?: string; actualEps?: string; actualNote?: string;
  };

  const CATEGORY_INFO: Record<string, string> = {
    'Inflacija': 'Meri spremembo cen (CPI – potrošniške cene) glede na leto/mesec prej. Višja inflacija od pričakovanj poveča verjetnost, da centralna banka obrestne mere obdrži višje dlje časa, kar navadno pritiska na delnice; nižja od pričakovanj deluje v obratno smer.',
    'Poraba': 'Meri gibanje maloprodaje - kazalnik moči potrošnika, ki predstavlja večino gospodarske aktivnosti v ZDA. Presenečenje navzgor kaže na odporno gospodarstvo, navzdol na upočasnjevanje povpraševanja.',
    'PMI': 'Indeks nabavnih menedžerjev meri razpoloženje podjetij v proizvodnji in storitvah. Vrednost nad 50 pomeni širitev gospodarske aktivnosti, pod 50 pa krčenje.',
    'Centralna banka': 'Odločitev osrednje banke (Fed ali ECB) o obrestnih merah. Dvig ali jastrebji ton (napoved prihodnjih dvigov) navadno okrepi valuto in pritisne na delnice; znižanje ali golobji ton deluje v obratno smer.',
    'GDP': 'Bruto domači proizvod meri skupno gospodarsko rast v četrtletju. Prva objava (advance) je zgodnja ocena, ki se kasneje revidira, ko so na voljo popolnejši podatki.',
    'Trg dela': 'Poročilo o novih delovnih mestih (NFP) oz. prijavah brezposelnih. Močan trg dela je dobra novica za gospodarsko rast, a lahko pomeni tudi več pritiska na inflacijo, kar podaljša obdobje višjih obrestnih mer.',
  };

  const EARNINGS_INFO = 'Četrtletno poročilo o poslovanju podjetja. Trg primerja dejanske rezultate (dobiček na delnico, prihodki) s pričakovanji analitikov (konsenz) - odstopanje od konsenza pogosto premakne ceno delnice bolj kot sami absolutni rezultati.';

  const MACRO_EVENTS: MacroEvent[] = koledarData.macroEvents as MacroEvent[];
  const EARNINGS: EarningsEvent[] = koledarData.earnings as EarningsEvent[];

  function parseDate(str: string): Date {
    const [y, m, d] = str.split('-').map(Number);
    return new Date(y, m - 1, d);
  }

  function weekKey(dateStr: string): string {
    const d = parseDate(dateStr);
    const mon = new Date(d);
    mon.setDate(d.getDate() - ((d.getDay() + 6) % 7));
    return mon.toISOString().slice(0, 10);
  }

  function weekLabel(mondayStr: string): string {
    const start = parseDate(mondayStr);
    const end = new Date(start);
    end.setDate(start.getDate() + 6);
    const fmtDay = (d: Date) => d.toLocaleDateString('sl-SI', { day: 'numeric', month: 'short' });
    return `${fmtDay(start)} – ${fmtDay(end)}`;
  }

  function dayLabel(dateStr: string): string {
    return parseDate(dateStr).toLocaleDateString('sl-SI', { weekday: 'short', day: 'numeric', month: 'numeric' });
  }

  function isToday(dateStr: string): boolean {
    const today = new Date();
    const d = parseDate(dateStr);
    return d.getFullYear() === today.getFullYear() &&
      d.getMonth() === today.getMonth() &&
      d.getDate() === today.getDate();
  }

  function isPast(dateStr: string): boolean {
    return parseDate(dateStr) < new Date(new Date().setHours(0, 0, 0, 0));
  }

  function badge(text: string, variant: string, extraClass = ''): string {
    return `<span class="cal-badge cal-badge--${variant} ${extraClass}">${text}</span>`;
  }

  function expandIcon(): string {
    return `<svg class="cal-expand-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>`;
  }

  function detailStat(label: string, value?: string): string {
    if (!value) return '';
    return `<div><strong>${label}:</strong> ${value}</div>`;
  }

  function renderMacroRow(evt: MacroEvent & { type: 'makro' }): string {
    const today_ = isToday(evt.date);
    const past = isPast(evt.date);
    const regionBadge = badge(evt.region === 'US' ? '🇺🇸 US' : '🇪🇺 EU', 'region');
    const catBadge = badge(evt.category, 'cat');
    const forecastHint = evt.forecast ? `<span class="cal-hint">napoved: ${evt.forecast}</span>` : '';
    const previousHint = evt.previous ? `<span class="cal-hint">prej: ${evt.previous}</span>` : '';
    const importanceBadge = badge(evt.importance === 'HIGH' ? 'VISOKO' : 'SREDNJE', evt.importance === 'HIGH' ? 'high' : 'medium');
    const actualBadge = evt.actual ? badge(`DEJANSKO: ${evt.actual}`, 'actual') : '';
    const description = CATEGORY_INFO[evt.category] || '';

    return `
      <div class="cal-item" data-id="${evt.id}">
        <button type="button" class="cal-row ${today_ ? 'cal-row--today' : ''} ${past ? 'cal-row--past' : ''}" aria-expanded="false">
          <div class="cal-date">
            <span class="cal-day">${dayLabel(evt.date)}${today_ ? ' ← danes' : ''}</span>
            ${evt.time ? `<span class="cal-time">${evt.time} CET</span>` : ''}
          </div>
          <div class="cal-main">
            <span class="cal-event-title">${evt.title}</span>
            <div class="cal-meta">${regionBadge}${catBadge}${actualBadge}${forecastHint}${previousHint}</div>
          </div>
          <div class="cal-row__end">${importanceBadge}${expandIcon()}</div>
        </button>
        <div class="cal-detail">
          ${description ? `<p>${description}</p>` : ''}
          <div class="cal-detail__stats">
            ${detailStat('Prejšnja vrednost', evt.previous)}
            ${detailStat('Napoved', evt.forecast)}
            ${detailStat('Dejanski rezultat', evt.actual)}
          </div>
        </div>
      </div>
    `;
  }

  function renderEarningsRow(evt: EarningsEvent & { type: 'zasluzki' }): string {
    const today_ = isToday(evt.date);
    const past = isPast(evt.date);
    const tickerBadge = badge(evt.ticker, 'region', 'cal-ticker');
    const usBadge = badge('🇺🇸 US', 'region');
    const earningsBadge = badge('Zaslužki', 'earnings');
    const hasStats = evt.prevEps || evt.estEps;
    const actualBadge = evt.actualEps ? badge(`DEJANSKO: ${evt.actualEps}`, 'actual') : '';
    const dateHint = evt.actualEps
      ? '<span class="cal-hint">poročano</span>'
      : '<span class="cal-hint">okvirni datum</span>';

    return `
      <div class="cal-item" data-id="${evt.id}">
        <button type="button" class="cal-row ${today_ ? 'cal-row--today' : ''} ${past ? 'cal-row--past' : ''}" aria-expanded="false">
          <div class="cal-date">
            <span class="cal-day">${dayLabel(evt.date)}${today_ ? ' ← danes' : ''}</span>
            <span class="cal-time">${evt.when}</span>
          </div>
          <div class="cal-main">
            <span class="cal-event-title">${evt.name} - Q2 2026</span>
            <div class="cal-meta">${tickerBadge}${usBadge}${earningsBadge}${actualBadge}${dateHint}</div>
          </div>
          <div class="cal-row__end">${expandIcon()}</div>
        </button>
        <div class="cal-detail">
          <p>${EARNINGS_INFO}</p>
          ${hasStats || evt.actualEps ? `
            <div class="cal-detail__stats">
              ${detailStat('Prejšnje četrtletje (EPS)', evt.prevEps)}
              ${detailStat('Napoved za to četrtletje (EPS, konsenz)', evt.estEps)}
              ${detailStat('Dejanski EPS', evt.actualEps)}
              ${detailStat('Opomba', evt.actualNote)}
            </div>
          ` : '<p class="cal-hint">Natančnejši podatki o dobičku bodo dodani bližje datumu objave.</p>'}
        </div>
      </div>
    `;
  }

  type Filter = 'vsi' | 'makro' | 'zasluzki';
  type CombinedEvent =
    | (MacroEvent & { type: 'makro' })
    | (EarningsEvent & { type: 'zasluzki' });

  function getFilteredEvents(filter: Filter): CombinedEvent[] {
    const macro = (filter === 'zasluzki' ? [] : MACRO_EVENTS).map(e => ({ ...e, type: 'makro' as const }));
    const earnings = (filter === 'makro' ? [] : EARNINGS).map(e => ({ ...e, type: 'zasluzki' as const }));
    return [...macro, ...earnings].sort(
      (a, b) => parseDate(a.date).getTime() - parseDate(b.date).getTime()
    );
  }

  function renderRow(evt: CombinedEvent): string {
    return evt.type === 'makro' ? renderMacroRow(evt) : renderEarningsRow(evt);
  }

  let currentFilter: Filter = 'vsi';
  let currentView: 'list' | 'month' = 'list';
  const today0 = new Date();
  today0.setHours(0, 0, 0, 0);
  let viewMonth = new Date(today0.getFullYear(), today0.getMonth(), 1);
  let selectedDate: string | null = null;

  function renderList(filter: Filter) {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const endDate = new Date(today);
    endDate.setDate(today.getDate() + 90);

    const allEvents = getFilteredEvents(filter).filter(e => {
      const d = parseDate(e.date);
      return d >= today && d <= endDate;
    });

    const container = document.getElementById('koledar-events')!;

    if (allEvents.length === 0) {
      container.innerHTML = '<div class="cal-empty">Ni prihajajočih dogodkov za izbrani filter.</div>';
      return;
    }

    const grouped = new Map<string, typeof allEvents>();
    for (const evt of allEvents) {
      const key = weekKey(evt.date);
      if (!grouped.has(key)) grouped.set(key, []);
      grouped.get(key)!.push(evt);
    }
    const groupedArr = Array.from(grouped.entries()).sort(([a], [b]) => a.localeCompare(b));

    container.innerHTML = groupedArr.map(([weekMon, events]) => `
      <div class="cal-week">
        <div class="cal-week__header">${weekLabel(weekMon)}</div>
        ${events.map(evt => renderRow(evt)).join('')}
      </div>
    `).join('');
  }

  function toDateKey(d: Date): string {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  function renderMonthGrid() {
    const label = viewMonth.toLocaleDateString('sl-SI', { month: 'long', year: 'numeric' });
    document.getElementById('cal-month-label')!.textContent = label;

    const events = getFilteredEvents(currentFilter);
    const eventsByDay = new Map<string, CombinedEvent[]>();
    for (const evt of events) {
      if (!eventsByDay.has(evt.date)) eventsByDay.set(evt.date, []);
      eventsByDay.get(evt.date)!.push(evt);
    }

    const firstOfMonth = new Date(viewMonth.getFullYear(), viewMonth.getMonth(), 1);
    const gridStart = new Date(firstOfMonth);
    gridStart.setDate(firstOfMonth.getDate() - ((firstOfMonth.getDay() + 6) % 7));

    const weekdayLabels = ['Pon', 'Tor', 'Sre', 'Čet', 'Pet', 'Sob', 'Ned'];
    let html = weekdayLabels.map(w => `<div class="cal-grid__weekday">${w}</div>`).join('');

    const cursor = new Date(gridStart);
    for (let i = 0; i < 42; i++) {
      const dateKey = toDateKey(cursor);
      const inMonth = cursor.getMonth() === viewMonth.getMonth();
      const isToday_ = dateKey === toDateKey(today0);
      const isSelected = dateKey === selectedDate;
      const dayEvents = eventsByDay.get(dateKey) || [];

      const colors = new Set<string>();
      for (const evt of dayEvents) {
        if (evt.type === 'zasluzki') colors.add('earnings');
        else colors.add(evt.importance === 'HIGH' ? 'high' : 'medium');
      }
      const dots = Array.from(colors).slice(0, 3)
        .map(c => `<span class="cal-day-dot cal-day-dot--${c}"></span>`).join('');

      const classes = [
        'cal-day-cell',
        !inMonth ? 'cal-day-cell--muted' : '',
        isToday_ ? 'cal-day-cell--today' : '',
        isSelected ? 'cal-day-cell--selected' : '',
        dayEvents.length > 0 ? 'cal-day-cell--has-events' : '',
      ].filter(Boolean).join(' ');

      html += `
        <button type="button" class="${classes}" data-date="${dateKey}" ${dayEvents.length === 0 ? 'disabled' : ''}>
          <span class="cal-day-num">${cursor.getDate()}</span>
          <span class="cal-day-dots">${dots}</span>
        </button>
      `;

      cursor.setDate(cursor.getDate() + 1);
    }

    document.getElementById('cal-grid')!.innerHTML = html;
    renderDayDetail();
  }

  function renderDayDetail() {
    const container = document.getElementById('cal-day-detail')!;
    if (!selectedDate) {
      container.innerHTML = '<p class="cal-day-detail__hint">Klikni na dan z dogodkom, da vidiš podrobnosti.</p>';
      return;
    }
    const events = getFilteredEvents(currentFilter).filter(e => e.date === selectedDate);
    if (events.length === 0) {
      container.innerHTML = '<p class="cal-day-detail__hint">Klikni na dan z dogodkom, da vidiš podrobnosti.</p>';
      return;
    }
    const label = parseDate(selectedDate).toLocaleDateString('sl-SI', { weekday: 'long', day: 'numeric', month: 'long' });
    container.innerHTML = `
      <div class="cal-week__header">${label}</div>
      ${events.map(evt => renderRow(evt)).join('')}
    `;
  }

  function setView(view: 'list' | 'month') {
    currentView = view;
    document.getElementById('koledar-events')!.hidden = view !== 'list';
    document.getElementById('koledar-month')!.hidden = view !== 'month';
    if (view === 'list') renderList(currentFilter);
    else renderMonthGrid();
  }

  const filterBtns = document.querySelectorAll<HTMLButtonElement>('#koledar-filters .filter-btn');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      currentFilter = btn.dataset.filter as Filter;
      if (currentView === 'list') renderList(currentFilter);
      else renderMonthGrid();
    });
  });

  const viewBtns = document.querySelectorAll<HTMLButtonElement>('#koledar-views .filter-btn');
  viewBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      viewBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      setView(btn.dataset.view as 'list' | 'month');
    });
  });

  document.getElementById('cal-prev')!.addEventListener('click', () => {
    viewMonth = new Date(viewMonth.getFullYear(), viewMonth.getMonth() - 1, 1);
    selectedDate = null;
    renderMonthGrid();
  });

  document.getElementById('cal-next')!.addEventListener('click', () => {
    viewMonth = new Date(viewMonth.getFullYear(), viewMonth.getMonth() + 1, 1);
    selectedDate = null;
    renderMonthGrid();
  });

  document.getElementById('cal-grid')!.addEventListener('click', (e) => {
    const cell = (e.target as HTMLElement).closest<HTMLButtonElement>('.cal-day-cell');
    if (!cell || cell.disabled) return;
    const date = cell.dataset.date!;
    selectedDate = selectedDate === date ? null : date;
    renderMonthGrid();
  });

  function attachExpandToggle(containerId: string) {
    document.getElementById(containerId)!.addEventListener('click', (e) => {
      const rowBtn = (e.target as HTMLElement).closest<HTMLButtonElement>('.cal-row');
      if (!rowBtn) return;
      const item = rowBtn.closest('.cal-item');
      if (!item) return;
      const isOpen = item.classList.toggle('cal-item--open');
      rowBtn.setAttribute('aria-expanded', String(isOpen));
    });
  }

  attachExpandToggle('koledar-events');
  attachExpandToggle('cal-day-detail');

  renderList('vsi');
</script>
