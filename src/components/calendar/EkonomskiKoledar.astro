---
---

<div class="koledar">
  <div class="koledar__header">
    <h1 class="koledar__title">Ekonomski koledar</h1>
    <p class="koledar__subtitle">
      Ključni makroekonomski dogodki in zaslužki največjih podjetij — naslednjih 90 dni.
      Časi so v CET/CEST. Datumi zaslužkov so okvirni.
    </p>
  </div>

  <div class="koledar__filters" id="koledar-filters" role="group" aria-label="Filtriraj dogodke">
    <button class="filter-btn filter-btn--active" data-filter="vsi">Vsi dogodki</button>
    <button class="filter-btn" data-filter="makro">Makro</button>
    <button class="filter-btn" data-filter="zasluzki">Zaslužki</button>
  </div>

  <div id="koledar-events"></div>
</div>

<style is:global>
  .koledar {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md) var(--space-3xl);
  }

  .koledar__header {
    margin-bottom: var(--space-xl);
  }

  .koledar__title {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }

  .koledar__subtitle {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .koledar__filters {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .filter-btn {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.375rem 1rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
    background: var(--color-surface-hover);
  }

  .filter-btn--active {
    color: var(--color-accent);
    background: var(--color-accent-bg);
    border-color: var(--color-accent-border);
    font-weight: 600;
  }

  .cal-week {
    margin-bottom: var(--space-xl);
  }

  .cal-week__header {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.75rem;
  }

  .cal-item {
    margin-bottom: 0.4rem;
  }

  .cal-row {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: border-color 150ms ease;
    cursor: pointer;
    width: 100%;
    text-align: left;
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    -webkit-appearance: none;
    appearance: none;
  }

  .cal-item .cal-row {
    border-bottom-left-radius: var(--radius-md);
    border-bottom-right-radius: var(--radius-md);
  }

  .cal-item--open .cal-row {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    border-bottom-color: transparent;
  }

  .cal-row:hover {
    border-color: var(--color-border-strong);
  }

  .cal-row--today {
    border-color: var(--color-accent-border);
    background: var(--color-accent-bg);
  }

  .cal-row--past {
    opacity: 0.5;
  }

  .cal-date {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cal-day {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .cal-row--today .cal-day {
    color: var(--color-accent);
  }

  .cal-time {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .cal-main {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .cal-event-title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
  }

  .cal-ticker {
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .cal-expand-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-subtle);
    transition: transform 150ms ease;
    flex-shrink: 0;
  }

  .cal-item--open .cal-expand-icon {
    transform: rotate(180deg);
  }

  .cal-meta {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .cal-hint {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .cal-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 1px 7px;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .cal-badge--high {
    background: rgba(220, 38, 38, 0.1);
    color: #dc2626;
    border: 1px solid rgba(220, 38, 38, 0.25);
  }

  .cal-badge--medium {
    background: rgba(217, 119, 6, 0.1);
    color: #b45309;
    border: 1px solid rgba(217, 119, 6, 0.25);
  }

  .cal-badge--earnings {
    background: rgba(37, 99, 235, 0.1);
    color: var(--color-accent);
    border: 1px solid var(--color-accent-border);
  }

  .cal-badge--region {
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    font-weight: 500;
  }

  .cal-badge--cat {
    background: var(--color-surface-hover);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .cal-empty {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .cal-row__end {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cal-detail {
    display: none;
    padding: 0.75rem 0.9rem 0.9rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: none;
    border-bottom-left-radius: var(--radius-md);
    border-bottom-right-radius: var(--radius-md);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .cal-item--open .cal-detail {
    display: block;
  }

  .cal-detail p {
    margin: 0 0 0.5rem;
  }

  .cal-detail__stats {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cal-detail__stats strong {
    color: var(--color-text);
    font-weight: 600;
  }
</style>

